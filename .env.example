# Supabase Configuration
# Replace these with your project's credentials from the Supabase Dashboard (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Security
# This password is required to enter the site through "The Gate"
# Default if not set: cuttergang
SITE_PASSWORD=your-secure-password
